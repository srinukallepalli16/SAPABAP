  METHOD GET_DATA.
    SELECT A~ONO A~ODATE A~PM A~CURR B~OIN B~ODESC B~ICOST FROM ZORDH_29 AS A INNER JOIN ZORDI_29 AS B ON A~ONO = B~ONO INTO TABLE LT_FINAL WHERE A~ONO = PONO.
  ENDMETHOD.


REPORT ZPRG_USUAL_CLASS_29.

PARAMETERS:P_ONO TYPE ZDEONO_28.

DATA:LT_OUTPUT TYPE ZTSTR_ORDER1.

DATA:LO_OBJECT TYPE REF TO ZUSUAL_ABAP_CLASS_29.
CREATE OBJECT LO_OBJECT.

CALL METHOD LO_OBJECT->GET_DATA
  EXPORTING
    PONO     = P_ONO
  IMPORTING
    LT_FINAL = LT_OUTPUT.

DATA:LT_FIELDCATLOG TYPE SLIS_T_FIELDCAT_ALV.

