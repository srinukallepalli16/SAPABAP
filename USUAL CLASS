  EXPORTING
    I_STRUCTURE_NAME       = 'ZSTR_ORDER1'
  CHANGING
    CT_FIELDCAT            = LT_FIELDCATLOG
  EXCEPTIONS
    INCONSISTENT_INTERFACE = 1
    PROGRAM_ERROR          = 2
    OTHERS                 = 3.
