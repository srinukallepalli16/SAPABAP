REPORT ZPRG9_28.


PARAMETERS:P_VBELN TYPE VBELN_VA.
PARAMETERS:P_R1 TYPE C RADIOBUTTON GROUP R1,
           P_R2 TYPE C RADIOBUTTON GROUP R1.


INTERFACE INTERFACE1.
  METHODS SALES IMPORTING PVBELN TYPE VBELN
                EXPORTING PERDAT TYPE ERDAT
                          PERZET TYPE ERZET
                          PERNAM TYPE ERNAM
                          PVBTYP TYPE VBTYP.
ENDINTERFACE.


INTERFACE INTERFACE2.
  METHODS BILLING IMPORTING PVBELN TYPE VBELN
                  EXPORTING PERDAT TYPE ERDAT
                            PERZET TYPE ERZET
                            PERNAM TYPE ERNAM
                            PVBTYP TYPE VBTYP.
ENDINTERFACE.

CLASS CLASS1 DEFINITION.
  PUBLIC SECTION.
    INTERFACES INTERFACE1.
    INTERFACES INTERFACE2.
ENDCLASS.

CLASS CLASS1 IMPLEMENTATION.
  METHOD INTERFACE1~SALES.
    SELECT SINGLE ERDAT ERNAM ERZET VBTYP FROM VBAK INTO ( PERDAT, PERNAM, PERZET, PVBTYP ) WHERE VBELN = PVBELN.
  ENDMETHOD.
  METHOD INTERFACE2~BILLING.
    SELECT SINGLE ERDAT ERNAM ERZET VBTYP FROM VBRK INTO ( PERDAT, PERNAM, PERZET, PVBTYP ) WHERE VBELN = PVBELN.
  ENDMETHOD.
ENDCLASS.

START-OF-SELECTION.
  DATA:LV_ERDAT TYPE ERDAT,
       LV_ERNAM TYPE ERNAM,
       LV_ERZET TYPE ERZET,
       LV_VBTYP TYPE VBTYP.

  DATA:LO_OBJECT1 TYPE REF TO CLASS1.
  IF P_R1 = 'X'.
    CREATE OBJECT LO_OBJECT1.
    LO_OBJECT1->INTERFACE1~SALES(
          EXPORTING
            PVBELN = P_VBELN
          IMPORTING
            PERDAT = LV_ERDAT
            PERNAM = LV_ERNAM
            PERZET = LV_ERZET
            PVBTYP = LV_VBTYP
    ).
    WRITE:/ 'Sales Order Details:', LV_ERDAT, LV_ERNAM,LV_ERZET,LV_VBTYP.

  ELSEIF P_R2 = 'X'.
    DATA:LO_OBJECT2 TYPE REF TO CLASS1.
    CREATE OBJECT LO_OBJECT2.
    LO_OBJECT2->INTERFACE2~BILLING(
       EXPORTING
         PVBELN = P_VBELN
       IMPORTING
         PERDAT = LV_ERDAT
         PERNAM = LV_ERNAM
         PERZET = LV_ERZET
         PVBTYP = LV_VBTYP
    ).
    WRITE:/ 'Billing Details:', LV_ERDAT, LV_ERNAM,LV_ERZET,LV_VBTYP.
  ENDIF.
