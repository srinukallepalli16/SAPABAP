FORM SEND_EMAIL .
  LS_TEXT-LINE = 'Hi Team,'(007).
  APPEND LS_TEXT TO LT_TEXT.
  CLEAR LS_TEXT.

  APPEND LS_TEXT TO LT_TEXT.

  LS_TEXT-LINE = 'Below Users are assigned with critical roles (SAP_ALL/SAP_NEW):'(008).
  APPEND LS_TEXT TO LT_TEXT.
  CLEAR LS_TEXT.

  APPEND LS_TEXT TO LT_TEXT.

  LS_TEXT-LINE = 'UserID     Profile    Date'(009).
  APPEND LS_TEXT TO LT_TEXT.
  CLEAR LS_TEXT.

  LS_TEXT-LINE = '----------------------------------------'(010).
  APPEND LS_TEXT TO LT_TEXT.
  CLEAR LS_TEXT.

  LOOP AT LT_MAIL INTO LS_MAIL.
    LS_TEXT-LINE = |{ LS_MAIL-BNAME }    { LS_MAIL-PROFILE }    { LS_MAIL-MODDA }|.
    APPEND LS_TEXT TO LT_TEXT.
    CLEAR LS_TEXT.
  ENDLOOP.
  APPEND LS_TEXT TO LT_TEXT.

  LS_TEXT-LINE = 'Thanks & Regards,'(011).
  APPEND LS_TEXT TO LT_TEXT.
  CLEAR LS_TEXT.

  LS_TEXT-LINE = 'SAP System'(012).
  APPEND LS_TEXT TO LT_TEXT.
  CLEAR LS_TEXT.

  IF LT_MAIL IS NOT INITIAL. "AND S_MAIL <> ''.
*    IF  S_MAIL <> ''.
    TRY.
        DATA:LO_BCS TYPE REF TO CL_BCS.
        CALL METHOD CL_BCS=>CREATE_PERSISTENT
          RECEIVING
            RESULT = LO_BCS.
      CATCH CX_SEND_REQ_BCS.
    ENDTRY.
*
*  "CREATE THE EXTERNAL USER
*    DATA:LV_MAIL_ADDRESS TYPE AD_SMTPADR VALUE P_MAIL.
    DATA:LO_EXTERNAL_MAIL TYPE REF TO CL_CAM_ADDRESS_BCS.
    LOOP AT S_MAIL INTO LWS_MAIL WHERE SIGN = 'I' AND OPTION = 'EQ'.

      TRY.
          LO_EXTERNAL_MAIL =
           CL_CAM_ADDRESS_BCS=>CREATE_INTERNET_ADDRESS( LWS_MAIL-LOW ).
*          EXPORTING
*            I_ADDRESS_STRING = P_MAIL
*           I_ADDRESS_NAME   =
*           I_INCL_SAPUSER   =
*          RECEIVING
*            RESULT           = LO_EXTERNAL_MAIL.
        CATCH CX_ADDRESS_BCS.
          CONTINUE.
      ENDTRY.
*
*  "ADD THE EXTERNAL USER AS RECIPIENT

      TRY.
          CALL METHOD LO_BCS->ADD_RECIPIENT( I_RECIPIENT = LO_EXTERNAL_MAIL ).
*          EXPORTING
*            I_RECIPIENT = LO_EXTERNAL_MAIL
*           I_EXPRESS   =
*           I_COPY      =
*           I_BLIND_COPY =
*           I_NO_FORWARD =
          .
        CATCH CX_SEND_REQ_BCS.
      ENDTRY.
    ENDLOOP.
    DATA:LV_SUBJECT TYPE SO_OBJ_DES VALUE 'Alert: Critical Role Assignment Notification'.
    DATA:LO_DOCUMENT TYPE REF TO CL_DOCUMENT_BCS.
    TRY.
        CALL METHOD CL_DOCUMENT_BCS=>CREATE_DOCUMENT
          EXPORTING
            I_TYPE    = 'RAW'
            I_SUBJECT = LV_SUBJECT
*           I_LENGTH  =
*           I_LANGUAGE      = SPACE
*           I_IMPORTANCE    =
*           I_SENSITIVITY   =
            I_TEXT    = LT_TEXT
*           I_HEX     =
*           I_HEADER  =
*           I_SENDER  =
*           IV_VSI_PROFILE  =
*           IV_VSI_SCAN_OFF =
          RECEIVING
            RESULT    = LO_DOCUMENT.
      CATCH CX_DOCUMENT_BCS.
    ENDTRY.
*  "SET THE DOCUMENT
    TRY.
        CALL METHOD LO_BCS->SET_DOCUMENT
          EXPORTING
            I_DOCUMENT = LO_DOCUMENT.
      CATCH CX_SEND_REQ_BCS.
    ENDTRY.
*
*  "ACTIVATE/DEACTIVATE IMMEDIATE SENDING
    TRY.
        CALL METHOD LO_BCS->SET_SEND_IMMEDIATELY
          EXPORTING
            I_SEND_IMMEDIATELY = ''.
      CATCH CX_SEND_REQ_BCS.
    ENDTRY.
*
*  "SEND THE MAIL
*  DATA:LV_RESULT TYPE BOOLEAN.
    TRY.
        CALL METHOD LO_BCS->SEND
*    EXPORTING
*      I_WITH_ERROR_SCREEN = SPACE
          RECEIVING
            RESULT = LV_RESULT.
      CATCH CX_SEND_REQ_BCS.
    ENDTRY.
*
    IF LV_RESULT = 'X'.
      MESSAGE S015(ZMESSAGE_3).
      COMMIT WORK.
    ENDIF.
*    ENDIF.
  ELSE.
    MESSAGE E016(ZMESSAGE_3).
  ENDIF.
ENDFORM.
