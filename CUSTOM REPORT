FORM GET_DATA .
*  SELECT BNAME MODDA MODBE FROM USR04 INTO TABLE LT_USERS WHERE MODDA IN S_DATE.
*  IF LT_USERS IS NOT INITIAL.
*    SELECT BNAME PROFILE FROM UST04 INTO TABLE LT_PROF FOR ALL ENTRIES IN LT_USERS WHERE BNAME = LT_USERS-BNAME. "AND ( PROFILE = 'SAP_ALL' OR PROFILE = 'SAP_NEW' ) .
*  ENDIF.
*  LOOP AT LT_USERS INTO LS_USERS.
*    LOOP AT LT_PROF INTO LS_PROF WHERE BNAME = LS_USERS-BNAME.
**     READ TABLE LT_PROF INTO LS_PROF WITH KEY BNAME = LS_USERS-BNAME.
*      LS_FINAL-BNAME = LS_USERS-BNAME.
*      LS_FINAL-MODDA = LS_USERS-MODDA.
*      LS_FINAL-MODBE = LS_USERS-MODBE.
*      LS_FINAL-PROFILE = LS_PROF-PROFILE.
*      APPEND LS_FINAL TO LT_FINAL.
*      CLEAR:LS_FINAL.
*    ENDLOOP.
*  ENDLOOP.
  SELECT A~BNAME, A~MODDA, A~MODBE, B~PROFILE
  FROM USR04 AS A INNER JOIN UST04 AS B
  ON A~BNAME = B~BNAME
  INTO TABLE @LT_FINAL WHERE A~MODDA IN @S_DATE.
ENDFORM.
